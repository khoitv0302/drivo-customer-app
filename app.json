{
  "expo": {
    "name": "drivo-customer-app",
    "slug": "drivo-customer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thanhtv62929.drivocustomerapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Drivo cần truy cập vị trí để xác định điểm đón và tìm tài xế gần bạn.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Drivo cần truy cập vị trí để xác định điểm đón và tìm tài xế gần bạn.",
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "sslip.io": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.thanhtv62929.drivocustomerapp",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "@rnmapbox/maps"
    ],
    "extra": {
      "eas": {
        "projectId": "64da7131-8f53-4f4c-a51b-8b011440c1be"
      }
    }
  }
}
